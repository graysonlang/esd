{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "esbuild:debug",
      "type": "npm",
      "script": "debug",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "severity": "info",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "\\[esbuild-ready\\]"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
