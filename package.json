{
  "name": "esd",
  "version": "0.1.0",
  "private": true,
  "description": "esbuild debugging",
  "keywords": [],
  "homepage": "https://github.com/graysonlang/esd#readme",
  "bugs": {
    "url": "https://github.com/graysonlang/esd/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graysonlang/esd.git"
  },
  "license": "MIT",
  "author": "Grayson Lang",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prepare": "node ./scripts/build.mjs --sync-launch",

    "ports": "node ./scripts/build.mjs --print-port",
    "sync:launch": "node ./scripts/build.mjs --sync-launch",
    "build": "node ./scripts/build.mjs --lint --minify",
    "serve": "node ./scripts/build.mjs --lint --sourcemap --watch --serve --debug-port=auto",
    "serve:https": "ESP_DEV_CERT_NAME=$npm_package_config_esp_dev_cert_name npm run serve -- --host=0.0.0.0",

    "dev": "npm run serve -- --proxy --launch",
    "dev:https": "npm run serve:https -- --proxy --launch",

    "vscode:build": "npm run build -- --vscode",
    "vscode:debug": "npm run serve -- --vscode",
    "vscode:debug:https": "npm run serve:https -- --vscode",

    "cert:dev": "ESP_DEV_CERT_NAME=$npm_package_config_esp_dev_cert_name esp-generate-dev-cert",
    "lint": "eslint . --ignore-pattern 'dist'",

    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@graysonlang/esp": "^1.7.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4"
  }
}
